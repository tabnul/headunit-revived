    <string name="supported_nativeaa">Hỗ trợ không dây nâng cao</string>
    <string name="supported_nativeaa_desc">Tin tốt! Máy của bạn hỗ trợ chế độ \"Native Wireless\", mang lại trải nghiệm Android Auto liền mạch hơn. \n\nĐể bật, cần làm mới bộ nhớ đệm Bluetooth. Vui lòng: \n1. Xoá ghép nối hiện có trên điện thoại \n2. Bấm OK để khởi động lại Bluetooth \n3. Ghép nối lại điện thoại \n\nBạn có muốn chuyển sang chế độ Native AA bây giờ?</string>
    <string name="not_supported_nativeaa">Có vẻ chưa hỗ trợ Native Wireless</string>
    <string name="not_supported_nativeaa_desc">Máy của bạn có thể không hỗ trợ các tính năng Bluetooth hoặc Wi-Fi cần cho Native Wireless. Bạn vẫn có thể thử, nhưng nếu thất bại hãy dùng chế độ \"Wireless Helper\" hoặc \"Auto (Headunit Server)\".</string>

    <string name="wait_for_wifi">Chờ WiFi trước khi dùng WiFi Direct</string>
    <string name="wait_for_wifi_description">Khi khởi động, chờ WiFi kết nối trước khi bắt đầu WiFi Direct. Bật nếu headunit cần vài giây để kết nối WiFi sau khi bật nguồn.</string>
    <string name="wait_for_wifi_timeout">Thời gian chờ WiFi</string>
