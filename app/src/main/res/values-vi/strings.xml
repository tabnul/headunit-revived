    <!-- Safety Disclaimer -->
    <string name="disclaimer_title">An toàn &amp; Trách nhiệm</string>
    <string name="disclaimer_header">Cảnh báo quan trọng</string>
    <string name="disclaimer_accept">Tôi đã hiểu và đồng ý</string>
    <string name="disclaimer_text"><![CDATA[
        <b>1. Tập trung khi lái xe</b><br/>
        Sử dụng phần mềm này khi đang lái có thể gây mất tập trung và nguy hiểm. Hãy ưu tiên lái xe an toàn và tuân thủ luật giao thông địa phương. Chỉ dùng ứng dụng khi an toàn để làm vậy.<br/><br/>
        <b>2. Giới hạn trách nhiệm</b><br/>
        Headunit Revived được cung cấp "nguyên trạng" không kèm bảo hành dưới bất kỳ hình thức nào. Nhà phát triển không chịu trách nhiệm với bất kỳ tai nạn, hư hỏng phương tiện/thiết bị hay hậu quả pháp lý nào phát sinh từ việc sử dụng phần mềm.<br/><br/>
        <b>3. Không liên kết</b><br/>
        Dự án này là sáng kiến mã nguồn mở độc lập, không liên kết, không được bảo trợ và không liên quan tới Google LLC hay thương hiệu Android Auto.
    ]]></string>

