<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="?android:attr/selectableItemBackground">

    <TextView
        android:id="@+id/settingName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="Wireless Mode" />

    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/settingName"
        app:layout_constraintEnd_toEndOf="parent">
        
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption1"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:padding="2dp"
            android:minHeight="54dp"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/segmented_button_stroke_selector"
            android:checkable="true"
            tools:text="Wireless Helper" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption2"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="-2dp"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:padding="2dp"
            android:minHeight="54dp"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/segmented_button_stroke_selector"
            android:checkable="true"
            tools:text="Native" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOption3"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="-2dp"
            android:textSize="12sp"
            android:textAllCaps="false"
            android:padding="2dp"
            android:minHeight="54dp"
            android:gravity="center"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="@color/segmented_button_stroke_selector"
            android:checkable="true"
            tools:text="Headunit Server" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
