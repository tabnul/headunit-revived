<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground">

    <!-- Main content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/loading_screen"
            app:navigationIcon="@drawable/ic_arrow_back_white"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:navigationIconTint="?android:attr/textColorPrimary" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Preview area -->
                <FrameLayout
                    android:id="@+id/preview_area"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="#FF000000">

                    <LinearLayout
                        android:id="@+id/preview_placeholder"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/loading_screen_no_media"
                            android:textColor="#66FFFFFF"
                            android:textSize="14sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/loading_screen_tap_preview"
                            android:textColor="#44FFFFFF"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/preview_image"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                    <!-- Status text overlay on preview (centered, matching real overlay) -->
                    <LinearLayout
                        android:id="@+id/preview_status_text"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:visibility="gone">

                        <ProgressBar
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:indeterminate="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="@string/android_auto_starting"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:shadowColor="#AA000000"
                            android:shadowDx="1"
                            android:shadowDy="1"
                            android:shadowRadius="3" />

                    </LinearLayout>

                </FrameLayout>

                <!-- Info -->
                <TextView
                    android:id="@+id/recommendation_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/aspect_ratio_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/loading_screen_supported_formats"
                    android:textColor="#AAAAAA"
                    android:textSize="13sp" />

                <!-- Toggles -->
                <LinearLayout
                    android:id="@+id/toggle_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/loading_screen_show_text"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="15sp" />

                        <Switch
                            android:id="@+id/toggle_show_text"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/loading_screen_keep_aspect_ratio"
                            android:textColor="?android:attr/textColorPrimary"
                            android:textSize="15sp" />

                        <Switch
                            android:id="@+id/toggle_keep_aspect_ratio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Buttons (max width for landscape) -->
                <Button
                    android:id="@+id/btn_select_file"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:maxWidth="400dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/loading_screen_select_file" />

                <Button
                    android:id="@+id/btn_remove"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxWidth="400dp"
                    android:layout_gravity="center_horizontal"
                    android:text="@string/loading_screen_remove"
                    android:visibility="gone"
                    android:background="?android:attr/selectableItemBackground"
                    android:textColor="#FF6B6B" />

            </LinearLayout>

        </ScrollView>

    </LinearLayout>

    <!-- Fullscreen preview overlay -->
    <FrameLayout
        android:id="@+id/fullscreen_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FF000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ImageView
            android:id="@+id/fullscreen_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:id="@+id/fullscreen_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:indeterminate="true" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/android_auto_starting"
                android:textColor="#CCFFFFFF"
                android:textSize="22sp" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="24dp"
            android:text="@string/loading_screen_tap_to_close"
            android:textColor="#66FFFFFF"
            android:textSize="13sp" />

    </FrameLayout>

</FrameLayout>
