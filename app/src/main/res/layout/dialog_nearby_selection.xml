<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="8dp"
    android:paddingBottom="16dp">

    <!-- Device List Container -->
    <LinearLayout
        android:id="@+id/listContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/searchingText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/searching"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp"
            android:visibility="visible"
            android:layout_marginBottom="8dp" />

        <ListView
            android:id="@+id/deviceList"
            android:layout_width="match_parent"
            android:layout_height="320dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:divider="@null" />
    </LinearLayout>

    <!-- Connecting Container (Hidden by default) -->
    <LinearLayout
        android:id="@+id/connectingContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="24dp">

        <ProgressBar
            android:id="@+id/connectionProgress"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@color/brand_teal"
            android:indeterminateTintMode="src_in" />

        <TextView
            android:id="@+id/connectingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/connecting_to_nearby"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="16sp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
